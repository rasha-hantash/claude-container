# Copy to .env and fill in values
# Claude auth is handled automatically via host keychain (see scripts/run.sh)
#
# Tokens are passed to the container as Docker secrets (file-mounted at
# /run/secrets/), NOT as environment variables. This prevents them from
# appearing in `docker compose config` or `docker inspect` output.
GITHUB_TOKEN=github_pat_...
GT_AUTH_TOKEN=...
GIT_USER_NAME=Rasha Hantash
GIT_USER_EMAIL=your@email.com
